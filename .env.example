# ============================================
# THEIA - Environment Configuration
# ============================================
# Copy to .env and adjust values for your setup.
# On Pi, install.sh will handle this automatically.

# --- Mode ---
# preview = mock data on Vercel / local dev
# pi      = real backend on Raspberry Pi
NEXT_PUBLIC_MODE=preview

# --- API ---
# Frontend always fetches from /api (Next.js routes)
# In pi mode, Next.js routes proxy to THEIA_BACKEND_URL
NEXT_PUBLIC_API_URL=/api
THEIA_BACKEND_URL=http://localhost:8000

# --- Database ---
DB_PATH=/opt/theia/data/theia.db

# --- GPS ---
# Uses gpsd socket (not direct serial). Leave empty to skip GPS port exclusion.
# If set, this port is excluded from LoRa scanning.
# Prefer /dev/theia-gps (udev symlink) over /dev/ttyUSBx.
GPS_DEVICE=

# --- LoRa ---
# Leave empty for auto-detection (/dev/theia-rx udev symlink, then /dev/ttyUSB* scan).
# Set explicitly only if auto-detection fails.
LORA_SERIAL_PORT=
LORA_BAUD_RATE=115200

# --- Authentication ---
# Secret key for JWT tokens. Auto-generated if empty.
# Set a fixed value for tokens to survive restarts:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# --- Web Push (VAPID) ---
# Auto-generated on first start if empty.
# VAPID_PRIVATE_KEY=
# VAPID_PUBLIC_KEY=
VAPID_CONTACT_EMAIL=admin@theia.local

# --- Map ---
# online  = fetch tiles from OpenStreetMap CDN
# offline = serve tiles from local storage
MAP_MODE=online
MAP_TILE_DIR=/opt/theia/tiles
