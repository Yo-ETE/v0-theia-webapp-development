[Unit]
Description=THEIA API (FastAPI/Uvicorn)
After=network.target gpsd.service
Wants=gpsd.service

[Service]
Type=simple
User=pi
Group=pi
WorkingDirectory=/opt/theia/app
EnvironmentFile=/opt/theia/app/.env
ExecStart=/opt/theia/app/.venv/bin/uvicorn backend.main:app --host 0.0.0.0 --port 8000 --workers 1
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=theia-api

[Install]
WantedBy=multi-user.target
